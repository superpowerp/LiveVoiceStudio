# Application
APP_ENV=development
APP_DEBUG=true
BASE_URL=http://localhost

# Database
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=livevoice_studio
DB_USER=root
DB_PASSWORD=

# WebSocket
WEBSOCKET_HOST=localhost
WEBSOCKET_PORT=8080
WEBSOCKET_SECURE=false

# TTS & Translation
TTS_ENGINE=google
TRANSLATION_ENGINE=google
TRANSLATION_API_KEY=

# Session
SESSION_DRIVER=file
SESSION_LIFETIME=3600

# Email (สำหรับ notifications)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# YouTube API
YOUTUBE_API_KEY=

# Twitch API (ภายหลัง)
TWITCH_CLIENT_ID=
TWITCH_ACCESS_TOKEN=

# TikTok API (ภายหลัง)
TIKTOK_API_KEY=
